<section class="tab how-to {{tab.cssClass}}" data-group="primary" data-tab="howTo">
  <div class="how-to-content">
    <div class="disclaimer">
      <i class="fas fa-triangle-exclamation"></i>
      <div>
        <strong>{{localize "SNOOT.HowTo.Disclaimer.Title"}}</strong>
        <p>{{localize "SNOOT.HowTo.Disclaimer.Body"}}</p>
      </div>
    </div>

    <h3>{{localize "SNOOT.HowTo.About.Title"}}</h3>
    <p>{{localize "SNOOT.HowTo.About.Body"}}</p>

    <div class="how-to-columns">
      <section>
        <h3>{{localize "SNOOT.HowTo.Status.Title"}}</h3>
        <dl class="status-glossary">
          <dt><span class="tag badge neutral">{{localize "SNOOT.Status.system"}}</span></dt>
          <dd>{{localize "SNOOT.HowTo.Status.System"}}</dd>

          <dt><span class="tag badge success">{{localize "SNOOT.Status.active"}}</span></dt>
          <dd>{{localize "SNOOT.HowTo.Status.Active"}}</dd>

          <dt><span class="tag badge warning">{{localize "SNOOT.Status.inactive"}}</span></dt>
          <dd>{{localize "SNOOT.HowTo.Status.Inactive"}}</dd>

          <dt><span class="tag badge error">{{localize "SNOOT.Status.orphaned"}}</span></dt>
          <dd>{{localize "SNOOT.HowTo.Status.Orphaned"}}</dd>

          <dt><i class="fas fa-hourglass-half stale-icon"></i> {{localize "SNOOT.HowTo.Status.StaleLabel"}}</dt>
          <dd>{{localize "SNOOT.HowTo.Status.Stale"}}</dd>
        </dl>
      </section>

      <section>
        <h3>{{localize "SNOOT.HowTo.Tabs.Title"}}</h3>
        <dl class="tabs-glossary">
          <dt><i class="fas fa-chart-pie"></i> {{localize "SNOOT.Tab.Overview"}}</dt>
          <dd>{{localize "SNOOT.HowTo.Tabs.Overview"}}</dd>

          <dt><i class="fas fa-cogs"></i> {{localize "SNOOT.Tab.Settings"}}</dt>
          <dd>{{localize "SNOOT.HowTo.Tabs.Settings"}}</dd>

          <dt><i class="fas fa-flag"></i> {{localize "SNOOT.Tab.FlagsWorld"}}</dt>
          <dd>{{localize "SNOOT.HowTo.Tabs.FlagsWorld"}}</dd>

          <dt><i class="fas fa-atlas"></i> {{localize "SNOOT.Tab.FlagsCompendiums"}}</dt>
          <dd>{{localize "SNOOT.HowTo.Tabs.FlagsCompendiums"}}</dd>
        </dl>
      </section>
    </div>

    <h3>{{localize "SNOOT.HowTo.Workflow.Title"}}</h3>
    <ol>
      <li>{{localize "SNOOT.HowTo.Workflow.Step1"}}</li>
      <li>{{localize "SNOOT.HowTo.Workflow.Step2"}}</li>
      <li>{{localize "SNOOT.HowTo.Workflow.Step3"}}</li>
      <li>{{localize "SNOOT.HowTo.Workflow.Step4"}}</li>
    </ol>
  </div>
</section>
