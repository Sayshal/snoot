<section class="tab settings-tab {{tab.cssClass}}" data-group="primary" data-tab="settings">
  <div class="tab-search">
    <i class="fas fa-search"></i>
    <input type="search" name="search" placeholder="{{localize "SNOOT.Search.Placeholder"}}" autocomplete="off"
      data-tooltip aria-label="{{localize "SNOOT.Tooltip.Search"}}">
  </div>

  {{#each settingsGroups}}
    <fieldset class="namespace-group collapsed {{this.status}}" data-namespace="{{this.namespace}}">
      <div class="namespace-header" data-action="toggleSection" data-tooltip
        aria-label="{{localize "SNOOT.Tooltip.Toggle"}}">
        <legend>
          <i class="fas fa-caret-down"></i>
          <span class="tag badge {{this.badgeClass}}">{{this.statusLabel}}</span>
          {{this.namespace}}
          <span class="count">({{this.count}})</span>
          {{#if this.hasStale}}<span class="stale-badge">{{this.staleCount}} stale</span>{{/if}}
        </legend>
        {{#if this.canClean}}
          <button type="button" data-action="deleteModuleSettings" data-namespace="{{this.namespace}}" data-tooltip
            aria-label="{{localize "SNOOT.Action.DeleteAll"}}">
            <i class="fas fa-trash"></i> {{localize "SNOOT.Action.DeleteAll"}}
          </button>
        {{/if}}
      </div>
      <div class="collapsible-content">
        <table class="settings-table">
          <thead>
            <tr>
              <th class="col-fit" data-tooltip aria-label="{{localize "SNOOT.Tooltip.Col.Key"}}">
                {{localize "SNOOT.Label.Key"}}
              </th>
              <th data-tooltip aria-label="{{localize "SNOOT.Tooltip.Col.Value"}}">{{localize "SNOOT.Label.Value"}}</th>
              <th class="col-btn" data-tooltip aria-label="{{localize "SNOOT.Tooltip.Col.Registered"}}"></th>
              <th class="col-btn" data-tooltip aria-label="{{localize "SNOOT.Tooltip.Col.Actions"}}"></th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </fieldset>
  {{/each}}

  {{#unless hasSettings}}
    <p class="empty-state">{{localize "SNOOT.Empty.Settings"}}</p>
  {{/unless}}
</section>
