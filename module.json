{
  "id": "snoot",
  "title": "Snoot",
  "version": "0.1.0",
  "description": "Uninstalled a module but its settings and flags are still cluttering your world? Snoot sniffs them out. It scans your documents and compendiums for orphaned data from modules that are gone or disabled, then groups it all by module so you can spot what's stale and clear it out in bulk.",
  "authors": [
    {
      "name": "Tyler",
      "discord": "Tyler",
      "url": "https://github.com/Sayshal",
      "flags": {}
    }
  ],
  "url": "https://github.com/Sayshal/snoot",
  "bugs": "https://github.com/Sayshal/snoot/issues",
  "changelog": "https://github.com/Sayshal/snoot/releases",
  "license": "https://github.com/Sayshal/snoot?tab=MIT-1-ov-file",
  "readme": "https://github.com/Sayshal/snoot?tab=readme-ov-file",
  "manifest": "https://github.com/Sayshal/snoot/releases/latest/download/module.json",
  "download": "",
  "compatibility": {
    "minimum": "13",
    "verified": "14.363"
  },
  "esmodules": [
    "scripts/snoot.mjs"
  ],
  "styles": [
    "styles/snoot.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": [
        "css",
        "html",
        "hbs",
        "json"
      ],
      "paths": [
        "styles",
        "lang",
        "templates"
      ]
    }
  }
}
